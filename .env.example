# Copie para .env e ajuste conforme necessário.
# Variáveis abaixo são opcionais; use quando acessar o app via proxy (ex: https://planeje.jbapex.com.br)
# para o Hot Module Replacement (HMR) do Vite conectar corretamente.

# HMR atrás de proxy (desative o erro "failed to connect to websocket")
# VITE_HMR_HOST=planeje.jbapex.com.br
# VITE_HMR_PROTOCOL=wss
# VITE_HMR_CLIENT_PORT=443
